# Copy to .env for local development. Never commit .env.

# Postgres connection string
# Railway provides this automatically when you add a Postgres plugin.
DATABASE_URL=postgres://user:password@localhost:5432/duo?sslmode=disable

# Secret used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32-byte-hex-string

# Port the server listens on (Railway sets this automatically)
PORT=8080
