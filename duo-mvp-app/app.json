{
  "expo": {
    "name": "DUO",
    "slug": "duo-mvp-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.duo.mvp",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "DUO uses Bluetooth to connect to your velocity tracker."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ],
    "scheme": "duo",
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true
  }
}
